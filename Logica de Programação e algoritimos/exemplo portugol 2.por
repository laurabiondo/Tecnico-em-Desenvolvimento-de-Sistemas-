programa {
  funcao inicio() {
    real baseMaior, BaseMenor, altura, area 
    escreva ("Base Maior:")
    leia (baseMaior)
    escreva ("Base Menor:")
    leia (BaseMenor)
    escreva ("altura:")
    leia (altura)
    area=((baseMaior+BaseMenor)*altura)/2
    escreva ("Área do trapésio:", area)
  }
}
